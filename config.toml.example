# ESEManager - example config (auto-created as config.toml on first run)

[download]
# Download directory (relative or absolute path)
directory = "Downloads"

# Parallel download threads (1-16)
workers = 5

[display]
# Kept for compatibility (not used by the current GUI)
page_size = 20

# UI language: "auto" (follow system), "zh_TW", "en", "ja"
ui_language = "auto"
